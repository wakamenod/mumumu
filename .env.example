# ─────────────────────────────────────────────────────
# 環境変数テンプレート
#
# このファイルを .env.local にコピーして実際の値を記入してください。
#   cp .env.example .env.local
#
# .env.local は .gitignore 済みのため Git にコミットされません。
# ─────────────────────────────────────────────────────

# ─── Firebase ─────────────────────────────────────────
# App Check デバッグトークン（development ビルド専用）
# 発行場所: Firebase Console > App Check > アプリ > デバッグトークンを管理
EXPO_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# ─── AdMob (iOS) ─────────────────────────────────────
# App ID（AdMob コンソール > アプリ > アプリ ID）
ADMOB_IOS_APP_ID=

# Ad Unit IDs（AdMob コンソール > 広告ユニット > 広告ユニット ID）
EXPO_PUBLIC_ADMOB_IOS_TAB_BANNER=
EXPO_PUBLIC_ADMOB_IOS_QUIZ_BANNER=
EXPO_PUBLIC_ADMOB_IOS_RESULT_BANNER=
